# ==========================================
#        AstraMusic Bot - Config
#   Fill in your values below (no quotes)
# ==========================================

# From my.telegram.org
API_ID=
API_HASH=

# From @BotFather on Telegram
BOT_TOKEN=

# From MongoDB Atlas
MONGO_DB_URI=

# Your Telegram log group ID (e.g. -1001234567890)
LOG_GROUP_ID=

# Bot display name
MUSIC_BOT_NAME=AstraMusic

# Your Telegram User ID
OWNER_ID=

# Your Pyrogram String Session (from @StringFatherBot)
STRING_SESSION=

# ==========================================
#       Optional Vars (leave blank)
# ==========================================

# Spotify integration (optional)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Support links (optional, must start with https://)
SUPPORT_CHANNEL=
SUPPORT_GROUP=

# Your forked repo URL
UPSTREAM_REPO=https://github.com/TeamYukki/YukkiMusicBot
UPSTREAM_BRANCH=master
GITHUB_REPO=

# Heroku (not needed for Koyeb)
HEROKU_API_KEY=
HEROKU_APP_NAME=
